    Else
        ws.Cells.Clear
        ws.Cells(1, 1).Value = "No."
        ws.Cells(1, 2).Value = "Date/Time"
        ws.Cells(1, 3).Value = "Item Index"
        ws.Cells(1, 4).Value = "Part Number"
